<resources>
    <!-- 基底テーマ -->
    <style name="Theme.Futaburakari" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- ツールバーのオーバーフローアイコンの色は専用styleで制御 -->
        <item name="actionOverflowButtonStyle">@style/OverflowButtonStyle</item>

        <!-- デフォルトカラー設定 -->
        <item name="colorPrimary">@color/my_expressive_primary</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- ブランドの第二色。 -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- ステータスバーの色。 -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.Futaburakari.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Futaburakari.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">24sp</item>
    </style>

</resources>
