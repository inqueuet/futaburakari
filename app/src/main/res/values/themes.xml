<resources>
    <!-- 基底テーマ（AppCompat）。
         画面内部は Compose の MaterialTheme を使用するため、
         XML 側は最小限（背景とカットアウト動作）のみ設定します。 -->
    <style name="Theme.Futaburakari" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:colorBackground">@color/my_expressive_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">default</item>
    </style>

    <!-- 既存の M3 オーバーレイは未使用のため削除。必要になれば AppCompat 相当を定義します。 -->

    <!-- ツールバーのタイトル用テキスト外観（AppCompat 由来のコンポーネント互換）。 -->
    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">24sp</item>
    </style>

</resources>
