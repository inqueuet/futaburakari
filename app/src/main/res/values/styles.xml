<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 入力フォームのラベル統一スタイル。fontScale に追従（sp）。 -->
    <style name="FormLabelText" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">10sp</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- カラーオーバーレイ（基底テーマの上に適用可能な差分定義）。
         Activity/Compose の setTheme でベースを選択しつつ、必要に応じてオーバーレイをかける用途。 -->
    <style name="ThemeOverlay.Futaburakari.Color.Green" parent="ThemeOverlay.Material3">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="ThemeOverlay.Futaburakari.Color.Purple" parent="ThemeOverlay.Material3">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="ThemeOverlay.Futaburakari.Color.Blue" parent="ThemeOverlay.Material3">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#26A69A</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="ThemeOverlay.Futaburakari.Color.Orange" parent="ThemeOverlay.Material3">
        <item name="colorPrimary">#EF6C00</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#00897B</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <!-- カラー別の完全なテーマ定義。`setTheme(...)` での切替用。
         Compose でも Activity テーマ経由で色が反映される。 -->
    <style name="Theme.Futaburakari.Green" parent="Theme.Futaburakari">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="Theme.Futaburakari.Purple" parent="Theme.Futaburakari">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="Theme.Futaburakari.Blue" parent="Theme.Futaburakari">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#26A69A</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="Theme.Futaburakari.Orange" parent="Theme.Futaburakari">
        <item name="colorPrimary">#EF6C00</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#00897B</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <!-- オーバーフローボタンのスタイル -->
    <style name="OverflowButtonStyle" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">?attr/colorOnPrimary</item>
    </style>

    <!-- ツールバー用のテーマオーバーレイ -->
    <style name="ThemeOverlay.Futaburakari.Toolbar" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:textColorPrimary">?attr/colorOnPrimary</item>
        <item name="android:textColorSecondary">?attr/colorOnPrimary</item>
        <item name="colorOnSurface">?attr/colorOnPrimary</item>
    </style>

    <!-- Preference 画面用オーバーレイ（要素のサマリー色をタイトル色に寄せる）。
         互換のため View ベース設定画面等で利用する想定。 -->
    <style name="ThemeOverlay.Futaburakari.Preference" parent="PreferenceThemeOverlay.v14.Material">
        <item name="android:textColorSecondary">?android:attr/textColorPrimary</item>
    </style>

</resources>
